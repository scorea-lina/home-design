# Example env file (safe to commit)
# Copy to .env.local and fill in values.

# Supabase (server-only unless otherwise specified)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required: gate extraction job endpoint
EXTRACT_JOBS_SECRET=dev-secret-change-me

# Required for LLM-based extraction (server only)
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL=

# Optional: database / Drizzle (legacy)
DATABASE_URL=

# Optional: app
NEXT_PUBLIC_APP_URL=
